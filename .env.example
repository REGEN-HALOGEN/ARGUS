# ─── ARGUS Environment Configuration ─────────────────────────────

# ─── Application ──────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_URL=http://localhost:3000
API_URL=http://localhost:4000

# ─── PostgreSQL (Supabase: Project Settings → Database → URI) ─────
# Use the DATABASE PASSWORD from that page (not the anon / service_role API keys).
# If the password has special characters (@ # : / etc.), URL-encode them in the URI
# (e.g. @ → %40). Postgres error 28P01 = wrong user/password or malformed URI.
# Example: postgresql://postgres:ENCODED_PASSWORD@db.xxxx.supabase.co:5432/postgres?sslmode=require
# If you see "self signed certificate in certificate chain" from pg on Windows, try (local dev only):
# DATABASE_SSL_INSECURE=true
# The db:test:pg script also retries with relaxed TLS when NODE_ENV=development (API still needs the flag above).

# ─── Neo4j ────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=argus_dev_password

# ─── Qdrant ───────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ─── Valkey (Redis-compatible) ────────────────────────────────────
VALKEY_URL=redis://localhost:6379

# ─── Google Gemini AI ─────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Better Auth ──────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-secret-key-change-in-production
BETTER_AUTH_URL=http://localhost:4000

# ─── Data Ingestion ──────────────────────────────────────────────
NVD_API_KEY=
OTX_API_KEY=
INGESTION_INTERVAL_HOURS=6
